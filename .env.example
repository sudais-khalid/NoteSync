# Root .env for docker-compose (cp .env.example .env, then fill in values).
# NEVER commit the real .env — it is gitignored.

# Secret used to sign JWTs. Generate one: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Optional: enables the Gemini enrichment pass on top of the classical NLP
# pipeline. The app works fully without it.
# Get a key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Public URL the frontend is served from (used for backend CORS).
FRONTEND_URL=http://localhost:3000
