# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/notesync
# OR use MongoDB Atlas (Free Tier):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/notesync

# Google Gemini API — optional. The NLP notes pipeline is classical/local and
# works without this; when set, Gemini adds a secondary enrichment pass.
# Get a key from: https://makersuite.google.com/app/apikey
# Never commit a real key here — this file is version-controlled.
GEMINI_API_KEY=your_gemini_api_key_here

# CORS Configuration (Frontend URL)
FRONTEND_URL=http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE=100MB
UPLOAD_PATH=./uploads