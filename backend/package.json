{
  "name": "notesync-backend",
  "version": "1.0.0",
  "description": "Backend API for NoteSync - AI-powered lecture note-taking application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/tests/jest.setup.js"
    ],
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "testTimeout": 30000
  },
  "keywords": [
    "lecture",
    "notes",
    "transcription",
    "AI",
    "education"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "compromise": "^14.15.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.20.0",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "natural": "^8.1.1",
    "validator": "^13.15.15",
    "wink-eng-lite-web-model": "^1.8.1",
    "wink-nlp": "^2.4.0",
    "wink-sentiment": "^5.0.2"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
